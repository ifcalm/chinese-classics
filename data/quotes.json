{
  "schemaVersion": 1,
  "_comment": "名句精选库（git 源）。text 逐字取自站内 base-data 源本（繁简随源），scripts/check-integrity.py 校验汉字流须原样命中出处篇章；chapterId 为站内阅读路径（/read/<chapterId>）。构建时随 content:build 产出 dist-content/quotes.json 上 R2，scripts/sync-quotes-d1.mjs 同步 D1。改动本文件须重跑校验。",
  "quotes": [
    { "id": "lunyu-xueer", "text": "學而時習之，不亦說乎？有朋自遠方來，不亦樂乎？人不知而不慍，不亦君子乎？", "source": "《论语·学而》", "chapterId": "confucius/lun-yu/lun-yu-01" },
    { "id": "lunyu-sanxing", "text": "吾日三省吾身：為人謀而不忠乎？與朋友交而不信乎？傳不習乎？", "source": "《论语·学而》", "chapterId": "confucius/lun-yu/lun-yu-01" },
    { "id": "lunyu-wengu", "text": "溫故而知新，可以為師矣。", "source": "《论语·为政》", "chapterId": "confucius/lun-yu/lun-yu-02" },
    { "id": "lunyu-siwang", "text": "學而不思則罔，思而不學則殆。", "source": "《论语·为政》", "chapterId": "confucius/lun-yu/lun-yu-02" },
    { "id": "lunyu-zhaowen", "text": "朝聞道，夕死可矣。", "source": "《论语·里仁》", "chapterId": "confucius/lun-yu/lun-yu-04" },
    { "id": "lunyu-jianxian", "text": "見賢思齊焉，見不賢而內自省也。", "source": "《论语·里仁》", "chapterId": "confucius/lun-yu/lun-yu-04" },
    { "id": "lunyu-lezhi", "text": "知之者不如好之者，好之者不如樂之者。", "source": "《论语·雍也》", "chapterId": "confucius/lun-yu/lun-yu-06" },
    { "id": "lunyu-sanren", "text": "三人行，必有我師焉，擇其善者而從之，其不善者而改之。", "source": "《论语·述而》", "chapterId": "confucius/lun-yu/lun-yu-07" },
    { "id": "lunyu-hongyi", "text": "士不可以不弘毅，任重而道遠。", "source": "《论语·泰伯》", "chapterId": "confucius/lun-yu/lun-yu-08" },
    { "id": "lunyu-shizhe", "text": "逝者如斯夫！不舍晝夜。", "source": "《论语·子罕》", "chapterId": "confucius/lun-yu/lun-yu-09" },
    { "id": "lunyu-jisuo", "text": "己所不欲，勿施於人。", "source": "《论语·颜渊》", "chapterId": "confucius/lun-yu/lun-yu-12" },
    { "id": "mengzi-laolao", "text": "老吾老，以及人之老；幼吾幼，以及人之幼。", "source": "《孟子·梁惠王上》", "chapterId": "confucius/mengzi/mengzi-lianghuiwang" },
    { "id": "mengzi-tianshi", "text": "天時不如地利，地利不如人和。", "source": "《孟子·公孙丑下》", "chapterId": "confucius/mengzi/mengzi-gongsunchou" },
    { "id": "mengzi-dedao", "text": "得道者多助，失道者寡助。", "source": "《孟子·公孙丑下》", "chapterId": "confucius/mengzi/mengzi-gongsunchou" },
    { "id": "mengzi-fugui", "text": "富貴不能淫，貧賤不能移，威武不能屈，此之謂大丈夫。", "source": "《孟子·滕文公下》", "chapterId": "confucius/mengzi/mengzi-tenwengong" },
    { "id": "mengzi-youhuan", "text": "生於憂患而死於安樂。", "source": "《孟子·告子下》", "chapterId": "confucius/mengzi/mengzi-gaozi" },
    { "id": "daxue-mingde", "text": "大學之道，在明明德，在親民，在止於至善。", "source": "《大学》", "chapterId": "confucius/da-xue/da-xue" },
    { "id": "zhongyong-boxue", "text": "博學之，審問之，慎思之，明辨之，篤行之。", "source": "《中庸》", "chapterId": "confucius/zhong-yong/zhong-yong" },
    { "id": "shijing-guanju", "text": "關關雎鳩、在河之洲。窈窕淑女、君子好逑。", "source": "《诗经·周南·关雎》", "chapterId": "confucius/shi-jing/shi-jing-001" },
    { "id": "shijing-zhizi", "text": "死生契闊、與子成說。執子之手、與子偕老。", "source": "《诗经·邶风·击鼓》", "chapterId": "confucius/shi-jing/shi-jing-031" },
    { "id": "shijing-jianjia", "text": "蒹葭蒼蒼、白露為霜。所謂伊人、在水一方。", "source": "《诗经·秦风·蒹葭》", "chapterId": "confucius/shi-jing/shi-jing-129" },
    { "id": "shijing-yangliu", "text": "昔我往矣、楊柳依依。今我來思、雨雪霏霏。", "source": "《诗经·小雅·采薇》", "chapterId": "confucius/shi-jing/shi-jing-167" },
    { "id": "shijing-tashan", "text": "它山之石、可以攻玉。", "source": "《诗经·小雅·鹤鸣》", "chapterId": "confucius/shi-jing/shi-jing-184" },
    { "id": "yijing-qian", "text": "天行健，君子以自強不息。", "source": "《周易·乾卦·象传》", "chapterId": "confucius/yi-jing/upper/qian" },
    { "id": "yijing-kun", "text": "地勢坤，君子以厚德載物。", "source": "《周易·坤卦·象传》", "chapterId": "confucius/yi-jing/upper/kun" },
    { "id": "shangshu-man", "text": "滿招損，謙受益。", "source": "《尚书·大禹谟》", "chapterId": "confucius/shang-shu/shang-shu-003" },
    { "id": "liji-yu", "text": "玉不琢，不成器；人不學，不知道。", "source": "《礼记·学记》", "chapterId": "confucius/li-ji/li-ji-xue-ji" },
    { "id": "liji-jiaoxue", "text": "學，然後知不足，教，然後知困。", "source": "《礼记·学记》", "chapterId": "confucius/li-ji/li-ji-xue-ji" },
    { "id": "zuozhuan-duoxing", "text": "多行不義必自斃。", "source": "《左传·隐公元年》", "chapterId": "confucius/chun-qiu-zuo-zhuan/chun-qiu-zuo-zhuan-yin-gong" },
    { "id": "zuozhuan-juan", "text": "居安思危，思則有備，有備無患。", "source": "《左传·襄公十一年》", "chapterId": "confucius/chun-qiu-zuo-zhuan/chun-qiu-zuo-zhuan-xiang-gong" },
    { "id": "xiaojing-shenti", "text": "身體髮膚，受之父母，不敢毀傷，孝之始也。", "source": "《孝经·开宗明义》", "chapterId": "confucius/xiao-jing/xiao-jing" },
    { "id": "ddj-daokedao", "text": "道可道，非常道；名可名，非常名。", "source": "《道德经》", "chapterId": "taoism/classics/dao-de-jing" },
    { "id": "ddj-shui", "text": "上善若水。水善利万物而不争，处众人之所恶，故几于道。", "source": "《道德经》", "chapterId": "taoism/classics/dao-de-jing" },
    { "id": "ddj-zhiren", "text": "知人者智，自知者明。胜人者有力，自胜者强。", "source": "《道德经》", "chapterId": "taoism/classics/dao-de-jing" },
    { "id": "ddj-huofu", "text": "祸兮福之所倚，福兮祸之所伏。", "source": "《道德经》", "chapterId": "taoism/classics/dao-de-jing" },
    { "id": "ddj-xiaoxian", "text": "治大国若烹小鲜。", "source": "《道德经》", "chapterId": "taoism/classics/dao-de-jing" },
    { "id": "ddj-qianli", "text": "合抱之木，生于毫末；九层之台，起于累土；千里之行，始于足下。", "source": "《道德经》", "chapterId": "taoism/classics/dao-de-jing" },
    { "id": "ddj-tianwang", "text": "天网恢恢，疏而不失。", "source": "《道德经》", "chapterId": "taoism/classics/dao-de-jing" },
    { "id": "ddj-xinyan", "text": "信言不美，美言不信；善者不辩，辩者不善。", "source": "《道德经》", "chapterId": "taoism/classics/dao-de-jing" },
    { "id": "zz-kun", "text": "北冥有鱼，其名为鲲。鲲之大，不知其几千里也。", "source": "《庄子·逍遥游》", "chapterId": "butterfly/zhuangzi/xiao-yao-you" },
    { "id": "zz-bingsheng", "text": "天地与我并生，而万物与我为一。", "source": "《庄子·齐物论》", "chapterId": "butterfly/zhuangzi/qi-wu-lun" },
    { "id": "zz-yousheng", "text": "吾生也有涯，而知也无涯。", "source": "《庄子·养生主》", "chapterId": "butterfly/zhuangzi/yang-sheng-zhu" },
    { "id": "zz-jianghu", "text": "相濡以沫，不如相忘于江湖。", "source": "《庄子·大宗师》", "chapterId": "butterfly/zhuangzi/da-zhong-shi" },
    { "id": "zz-junzi", "text": "君子之交淡若水，小人之交甘若醴。", "source": "《庄子·山木》", "chapterId": "butterfly/zhuangzi/shan-mu" },
    { "id": "sunzi-zhibi", "text": "知彼知己，百戰不殆；不知彼而知己，一勝一負；不知彼不知己，每戰必殆。", "source": "《孙子兵法·谋攻》", "chapterId": "masters/sunzi-bingfa/sunzi-bingfa-003" },
    { "id": "sunzi-buzhan", "text": "百戰百勝，非善之善者也；不戰而屈人之兵，善之善者也。", "source": "《孙子兵法·谋攻》", "chapterId": "masters/sunzi-bingfa/sunzi-bingfa-003" },
    { "id": "sunzi-shangbing", "text": "上兵伐謀，其次伐交，其次伐兵，其下攻城。", "source": "《孙子兵法·谋攻》", "chapterId": "masters/sunzi-bingfa/sunzi-bingfa-003" },
    { "id": "xunzi-qinglan", "text": "靑，取之於藍而靑於藍；冰，水爲之而寒於水。", "source": "《荀子·劝学》", "chapterId": "masters/xunzi/quan-xue" },
    { "id": "xunzi-jinshi", "text": "鍥而舍之，朽木不折；鍥而不舍，金石可鏤。", "source": "《荀子·劝学》", "chapterId": "masters/xunzi/quan-xue" },
    { "id": "hanfei-loudi", "text": "千丈之堤，以螻蟻之穴潰；百尺之室，以突隙之煙焚。", "source": "《韩非子·喻老》", "chapterId": "masters/hanfeizi/yu-lao" },
    { "id": "guanzi-canglin", "text": "倉廩實則知禮節，衣食足則知榮辱。", "source": "《管子·牧民》", "chapterId": "masters/guanzi/guanzi-001" },
    { "id": "guanzi-shuren", "text": "一年之計，莫如樹穀；十年之計，莫如樹木；終身之計，莫如樹人。", "source": "《管子·权修》", "chapterId": "masters/guanzi/guanzi-003" },
    { "id": "mozi-jianai", "text": "天下兼相愛則治，交相惡則亂。", "source": "《墨子·兼爱上》", "chapterId": "masters/mozi/jian-ai-shang" },
    { "id": "lscq-liushui", "text": "流水不腐，戶樞不螻，動也。", "source": "《吕氏春秋·尽数》", "chapterId": "masters/lvshi-chunqiu/lvshi-chunqiu-003" },
    { "id": "zgc-qianshi", "text": "前事之不忘，後事之師。", "source": "《战国策·赵策》", "chapterId": "masters/zhanguoce/zhanguoce-018" },
    { "id": "zgc-wangyang", "text": "見兔而顧犬，未為晚也；亡羊而補牢，未為遲也。", "source": "《战国策·楚策》", "chapterId": "masters/zhanguoce/zhanguoce-017" },
    { "id": "yanzi-ju", "text": "橘生淮南，則為橘；生於淮北，則為枳。", "source": "《晏子春秋》", "chapterId": "masters/yanzi-chunqiu/yanzi-chunqiu-006" },
    { "id": "shuoyuan-riyang", "text": "少而好學，如日出之陽；壯而好學，如日中之光；老而好學，如炳燭之明。", "source": "《说苑·建本》", "chapterId": "masters/shuoyuan/shuoyuan-003" },
    { "id": "lunheng-wulou", "text": "知屋漏者在宇下，知政失者在草野。", "source": "《论衡·书解》", "chapterId": "masters/lun-heng/26-juan-26/78" },
    { "id": "yanshi-boji", "text": "积财千万，不如薄伎在身。", "source": "《颜氏家训·勉学》", "chapterId": "masters/yan-shi-jia-xun/08" },
    { "id": "cgt-fenglai", "text": "风来疏竹，风过而竹不留声；雁度寒潭，雁去而潭不留影。故君子事来而心始现，事去而心随空。", "source": "《菜根谭》", "chapterId": "masters/cai-gen-tan/04" },
    { "id": "wlyh-naifan", "text": "十分不耐烦，乃为人大病。一昧学吃亏，是处事良方。", "source": "《围炉夜话》", "chapterId": "masters/wei-lu-ye-hua/01" },
    { "id": "zhuzi-yizhou", "text": "一粥一飯，當思來處不易；半絲半縷，恆念物力維艱。", "source": "《朱子家训》", "chapterId": "mengxue/zhu-zi-jia-xun/zhu-zi-jia-xun" },
    { "id": "shiji-yanque", "text": "燕雀安知鴻鵠之志哉！", "source": "《史记·陈涉世家》", "chapterId": "history/shi-ji/shi-ji-048" },
    { "id": "shiji-wanghou", "text": "王侯將相寧有種乎！", "source": "《史记·陈涉世家》", "chapterId": "history/shi-ji/shi-ji-048" },
    { "id": "shiji-yunchou", "text": "運籌策帷帳之中，決勝於千里之外。", "source": "《史记·高祖本纪》", "chapterId": "history/shi-ji/shi-ji-008" },
    { "id": "shiji-zhizhe", "text": "智者千慮，必有一失；愚者千慮，必有一得。", "source": "《史记·淮阴侯列传》", "chapterId": "history/shi-ji/shi-ji-092" },
    { "id": "shiji-taoli", "text": "桃李不言，下自成蹊。", "source": "《史记·李将军列传》", "chapterId": "history/shi-ji/shi-ji-109" },
    { "id": "shiji-yiming", "text": "此鳥不飛則已，一飛沖天；不鳴則已，一鳴驚人。", "source": "《史记·滑稽列传》", "chapterId": "history/shi-ji/shi-ji-126" },
    { "id": "hanshu-taishan", "text": "人固有一死，死有重於泰山，或輕於鴻毛，用之所趨異也。", "source": "《汉书·司马迁传》", "chapterId": "history/han-shu/han-shu-062" },
    { "id": "hanshu-shuiqing", "text": "水至清則無魚，人至察則無徒。", "source": "《汉书·东方朔传》", "chapterId": "history/han-shu/han-shu-065" },
    { "id": "hhs-huxue", "text": "不入虎穴，不得虎子。", "source": "《后汉书·班超传》", "chapterId": "history/hou-han-shu/hou-han-shu-047" },
    { "id": "sgz-wuyi", "text": "勿以惡小而為之，勿以善小而不為。", "source": "《三国志·蜀书·先主传》", "chapterId": "history/san-guo-zhi/san-guo-zhi-032" },
    { "id": "sgz-guamu", "text": "士別三日，即更刮目相待。", "source": "《三国志·吴书·吕蒙传》", "chapterId": "history/san-guo-zhi/san-guo-zhi-054" },
    { "id": "sjz-sanxia", "text": "巴東三峽巫峽長，猿鳴三聲淚沾裳。", "source": "《水经注·江水》", "chapterId": "history/shui-jing-zhu/034" },
    { "id": "zztj-jianting", "text": "兼聽則明，偏信則暗。", "source": "《资治通鉴·唐纪》", "chapterId": "history/zi-zhi-tong-jian/zi-zhi-tong-jian-192" },
    { "id": "zgzy-tongjing", "text": "以銅為鏡，可以正衣冠；以古為鏡，可以知興替；以人為鏡，可以明得失。", "source": "《贞观政要·任贤》", "chapterId": "history/zhen-guan-zheng-yao/zhen-guan-zheng-yao-002" },
    { "id": "jiutangshu-yejing", "text": "業精於勤，荒於嬉；行成於思，毀於隨。", "source": "韩愈《进学解》", "chapterId": "history/jiu-tang-shu/jiu-tang-shu-160" },
    { "id": "chuci-lisao", "text": "路曼曼其脩遠兮，吾將上下而求索。", "source": "屈原《离骚》", "chapterId": "literature/chuci/chu-ci/chu-ci-001" },
    { "id": "chuci-yufu", "text": "舉世皆濁我獨清，衆人皆醉我獨醒。", "source": "《楚辞·渔父》", "chapterId": "literature/chuci/chu-ci/chu-ci-007" },
    { "id": "caocao-duijiu", "text": "对酒当歌，人生几何！譬如朝露，去日苦多。", "source": "曹操《短歌行》", "chapterId": "literature/cao-cao-shi-ji/002" },
    { "id": "caocao-laoji", "text": "老骥伏枥，志在千里。烈士暮年，壮心不已。", "source": "曹操《龟虽寿》", "chapterId": "literature/cao-cao-shi-ji/006" },
    { "id": "tao-caiju", "text": "采菊东篱下，悠然见南山。", "source": "陶渊明《饮酒》", "chapterId": "literature/tao-yuan-ming-ji/03-juan3/012" },
    { "id": "tao-shengnian", "text": "盛年不重来，一日难再晨；及时当勉励，岁月不待人。", "source": "陶渊明《杂诗》", "chapterId": "literature/tao-yuan-ming-ji/04-juan4/010" },
    { "id": "wxdl-caoqu", "text": "操千曲而后晓声，观千剑而后识器。", "source": "《文心雕龙·知音》", "chapterId": "literature/wen-xin-diao-long/48" },
    { "id": "tang-zhiji", "text": "海內存知己，天涯若比鄰。", "source": "王勃《送杜少府之任蜀州》", "chapterId": "literature/tang-shi-san-bai-shou/04-wu-yan-lyu-shi/001" },
    { "id": "tang-mingyue", "text": "明月松間照，清泉石上流。", "source": "王维《山居秋暝》", "chapterId": "literature/tang-shi-san-bai-shou/04-wu-yan-lyu-shi/009" },
    { "id": "tang-yehuo", "text": "野火燒不盡，春風吹又生。", "source": "白居易《赋得古原草送别》", "chapterId": "literature/tang-shi-san-bai-shou/04-wu-yan-lyu-shi/015" },
    { "id": "tang-jingye", "text": "床前明月光，疑是地上霜。舉頭望明月，低頭思故鄉。", "source": "李白《静夜思》", "chapterId": "literature/tang-shi-san-bai-shou/06-wu-yan-jue-ju/011" },
    { "id": "tang-chunxiao", "text": "春眠不覺曉，處處聞啼鳥。夜來風雨聲，花落知多少。", "source": "孟浩然《春晓》", "chapterId": "literature/tang-shi-san-bai-shou/06-wu-yan-jue-ju/018" },
    { "id": "tang-hongdou", "text": "紅豆生南國，春來發幾枝。願君多采擷，此物最相思。", "source": "王维《相思》", "chapterId": "literature/tang-shi-san-bai-shou/06-wu-yan-jue-ju/004" },
    { "id": "tang-youzi", "text": "誰言寸草心，報得三春暉。", "source": "孟郊《游子吟》", "chapterId": "literature/tang-shi-san-bai-shou/03-yue-fu/037" },
    { "id": "tang-jiajie", "text": "獨在異鄉爲異客，每逢佳節倍思親。", "source": "王维《九月九日忆山东兄弟》", "chapterId": "literature/tang-shi-san-bai-shou/07-qi-yan-jue-ju/004" },
    { "id": "tang-yueluo", "text": "月落烏啼霜滿天，江楓漁火對愁眠。姑蘇城外寒山寺，夜半鐘聲到客船。", "source": "张继《枫桥夜泊》", "chapterId": "literature/tang-shi-san-bai-shou/07-qi-yan-jue-ju/039" },
    { "id": "dufu-lingjue", "text": "會當凌絕頂，一覽衆山小。", "source": "杜甫《望岳》", "chapterId": "literature/du-gong-bu-ji/0028" },
    { "id": "dufu-dushu", "text": "讀書破萬卷，下筆如有神。", "source": "杜甫《奉赠韦左丞丈二十二韵》", "chapterId": "literature/du-gong-bu-ji/0024" },
    { "id": "libai-changfeng", "text": "長風破浪會有時，直挂雲帆濟滄海。", "source": "李白《行路难》", "chapterId": "literature/li-tai-bai-ji/0103" },
    { "id": "libai-tiansheng", "text": "天生我材必有用，千金散盡還復來。", "source": "李白《将进酒》", "chapterId": "literature/li-tai-bai-ji/0003" },
    { "id": "gwgz-xiantianxia", "text": "先天下之憂而憂，後天下之樂而樂。", "source": "范仲淹《岳阳楼记》", "chapterId": "literature/gu-wen-guan-zhi/09-juan-9/16" },
    { "id": "gwgz-buyiwuxi", "text": "不以物喜，不以己悲。", "source": "范仲淹《岳阳楼记》", "chapterId": "literature/gu-wen-guan-zhi/09-juan-9/16" },
    { "id": "gwgz-luoxia", "text": "落霞與孤鶩齊飛，秋水共長天一色。", "source": "王勃《滕王阁序》", "chapterId": "literature/gu-wen-guan-zhi/07-juan-7/09" },
    { "id": "gwgz-zuiweng", "text": "醉翁之意不在酒，在乎山水之間也。", "source": "欧阳修《醉翁亭记》", "chapterId": "literature/gu-wen-guan-zhi/10-juan-10/07" },
    { "id": "gwgz-jugong", "text": "鞠躬盡瘁，死而後已。", "source": "诸葛亮《后出师表》", "chapterId": "literature/gu-wen-guan-zhi/06-juan-6/16" },
    { "id": "gwgz-shouren", "text": "受任於敗軍之際，奉命於危難之間。", "source": "诸葛亮《出师表》", "chapterId": "literature/gu-wen-guan-zhi/06-juan-6/15" },
    { "id": "gwgz-loushi", "text": "山不在高，有仙則名。水不在深，有龍則靈。", "source": "刘禹锡《陋室铭》", "chapterId": "literature/gu-wen-guan-zhi/07-juan-7/13" },
    { "id": "gwgz-shishuo", "text": "師者，所以傳道受業解惑也。", "source": "韩愈《师说》", "chapterId": "literature/gu-wen-guan-zhi/08-juan-8/01" },
    { "id": "dongpo-danyuan", "text": "人有悲欢离合，月有阴晴圆缺，此事古难全。但愿人长久，千里共婵娟。", "source": "苏轼《水调歌头》", "chapterId": "literature/dong-po-ci/0012" },
    { "id": "jiaxuan-qianbai", "text": "众里寻他千百度。蓦然回首，那人却在，灯火阑珊处。", "source": "辛弃疾《青玉案·元夕》", "chapterId": "literature/jia-xuan-ci/0190" },
    { "id": "shuyu-lvfei", "text": "知否。知否。应是绿肥红瘦。", "source": "李清照《如梦令》", "chapterId": "literature/shu-yu-ci/0010" },
    { "id": "nantang-chunshui", "text": "问君能有几多愁？恰似一江春水向东流。", "source": "李煜《虞美人》", "chapterId": "literature/nan-tang-er-zhu-ci/02/01" },
    { "id": "nalan-chujian", "text": "人生若只如初见，何事秋风悲画扇。", "source": "纳兰性德《木兰花令》", "chapterId": "literature/na-lan-ci/002" },
    { "id": "rjch-jingjie", "text": "古今之成大事业、大学问者，必经过三种之境界。", "source": "王国维《人间词话》", "chapterId": "literature/ren-jian-ci-hua" },
    { "id": "szj-renzhichu", "text": "人之初，性本善，性相近，習相遠。", "source": "《三字经》", "chapterId": "mengxue/san-zi-jing/san-zi-jing" },
    { "id": "qzw-tiandi", "text": "天地玄黃，宇宙洪荒。", "source": "《千字文》", "chapterId": "mengxue/qian-zi-wen/qian-zi-wen" },
    { "id": "zgxw-sandong", "text": "好言一句三冬暖，話不投機六月寒。", "source": "《增广贤文》", "chapterId": "mengxue/zeng-guang-xian-wen/zeng-guang-xian-wen" },
    { "id": "zgxw-guangyin", "text": "一寸光陰一寸金，寸金難買寸光陰。", "source": "《增广贤文》", "chapterId": "mengxue/zeng-guang-xian-wen/zeng-guang-xian-wen" },
    { "id": "zgxw-luyao", "text": "路遙知馬力，日久見人心。", "source": "《增广贤文》", "chapterId": "mengxue/zeng-guang-xian-wen/zeng-guang-xian-wen" },
    { "id": "slqm-yunduiyu", "text": "雲對雨，雪對風，晚照對晴空。來鴻對去燕，宿鳥對鳴蟲。", "source": "《声律启蒙》", "chapterId": "mengxue/sheng-lyu-qi-meng/sheng-lyu-qi-meng" },
    { "id": "lwdy-tiandui", "text": "天对地，雨对风，大陆对长空。", "source": "《笠翁对韵》", "chapterId": "mengxue/li-weng-dui-yun/li-weng-dui-yun" },
    { "id": "jingang-mengying", "text": "一切有为法，如梦幻泡影，如露亦如电，应作如是观。", "source": "《金刚经》", "chapterId": "buddha/jingzang/bore/jing-gang-jing" },
    { "id": "xinjing-se", "text": "色不异空，空不异色。色即是空，空即是色。", "source": "《般若心经》", "chapterId": "buddha/jingzang/bore/xing-jing" },
    { "id": "tanjing-puti", "text": "菩提本無樹，明鏡亦非臺；本來無一物，何處惹塵埃？", "source": "《六祖坛经》", "chapterId": "buddha/zongpai/chan/liu-zu-da-shi-fa-bao-tan-jing/liu-zu-da-shi-fa-bao-tan-jing-001" },
    { "id": "neijing-zhiweibing", "text": "聖人不治已病治未病，不治已亂治未亂。", "source": "《黄帝内经·素问》", "chapterId": "medicine/huangdi-neijing/su-wen/su-wen-001" },
    { "id": "ssxy-liaoliao", "text": "小時了了，大未必佳！", "source": "《世说新语·言语》", "chapterId": "biji/shi-shuo-xin-yu/shi-shuo-xin-yu-002-yan-yu" },
    { "id": "taoan-pi", "text": "人无癖不可与交，以其无深情也；人无疵不可与交，以其无真气也。", "source": "张岱《陶庵梦忆》", "chapterId": "biji/tao-an-meng-yi/04-juan-4/14" },
    { "id": "fusheng-buyi", "text": "布衣菜饭，可乐终身。", "source": "沈复《浮生六记》", "chapterId": "biji/fu-sheng-liu-ji/01" },
    { "id": "ymy-kuiyue", "text": "少年读书，如隙中窥月；中年读书，如庭中望月；老年读书，如台上玩月。", "source": "张潮《幽梦影》", "chapterId": "biji/you-meng-ying/01" },
    { "id": "sanguo-changjiang", "text": "滾滾長江東逝水，浪花淘盡英雄。是非成敗轉頭空：青山依舊在，幾度夕陽紅。", "source": "《三国演义·开篇词》", "chapterId": "xiaoshuo/san-guo-yan-yi/001" },
    { "id": "sanguo-dashi", "text": "話說天下大勢，分久必合，合久必分。", "source": "《三国演义·第一回》", "chapterId": "xiaoshuo/san-guo-yan-yi/001" },
    { "id": "shuihu-youyuan", "text": "有缘千里来相会，无缘对面不相逢。", "source": "《水浒传·第十四回》", "chapterId": "xiaoshuo/shui-hu-zhuan/014" },
    { "id": "xiyou-renxin", "text": "人心生一念，天地盡皆知。善惡若無報，乾坤必有私。", "source": "《西游记·第八回》", "chapterId": "xiaoshuo/xi-you/xi-you-ji/008" },
    { "id": "honglou-jiazuo", "text": "假作真時真亦假，無為有處有還無。", "source": "《红楼梦·第一回》", "chapterId": "xiaoshuo/hong-lou-meng/001" },
    { "id": "honglou-shishi", "text": "世事洞明皆學問，人情練達即文章。", "source": "《红楼梦·第五回》", "chapterId": "xiaoshuo/hong-lou-meng/005" },
    { "id": "rulin-hedong", "text": "三十年河東，三十年河西！", "source": "《儒林外史·第四十六回》", "chapterId": "xiaoshuo/ru-lin-wai-shi/046" }
  ]
}
